# Cosentus voice-engine v2 — build-context filter for Layer 10.
#
# Aggressively narrow the build context to what the Dockerfile
# actually needs (``pyproject.toml``, ``README.md``, ``uv.lock``
# when present, ``backend/voice-agent/app/``). Everything else is
# excluded so ``docker build`` doesn't transfer hundreds of MB of
# test data, ngrok logs, virtualenvs, etc.

# ── Python tooling ───────────────────────────────────────────────────────
.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.ruff_cache/
.mypy_cache/
*.egg-info/
build/
dist/

# ── Node / web (defensive) ───────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── AWS CDK / future Layer 11 artifacts ──────────────────────────────────
cdk.out/
.cdk.staging/
cdk.context.json

# ── IDE / OS ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# ── Git + CI ──────────────────────────────────────────────────────────────
.git/
.github/
.gitignore
.gitattributes

# ── v2-specific test + scratch directories ───────────────────────────────
# Tests aren't shipped with the runtime image; they run in CI / locally.
backend/voice-agent/tests/
# Scripts are dev tooling (walking_skeleton, scale_test). Layer 10
# images don't need them, so don't ship.
backend/voice-agent/scripts/
# Scale-test outputs from Layer 9.5 (large; multi-MB engine logs).
scale_test_results/
soak_24h.log

# ── Documentation (out of v2's runtime path) ─────────────────────────────
docs/

# ── Lambda repo (sibling, not part of engine container) ──────────────────
cosentus-voice-api-lambda/

# ── Misc artifacts ───────────────────────────────────────────────────────
*.log
*.tar.gz
*.zip

# Note: README.md is intentionally NOT excluded — setuptools reads it
# at install time when ``readme = "README.md"`` is set in pyproject.

# Note: uv.lock is gitignored locally but DO ship if present in the
# build context — gives reproducible installs across rebuilds.
