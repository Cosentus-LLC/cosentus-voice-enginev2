# Per-environment CDK configuration. Copy to `.env.staging` or `.env.prod`
# and populate. These files are .gitignored — secrets and account-specific
# values do not live in version control.
#
# Values are also overridable via CDK context (`-c key=value`) at synth /
# deploy time; context wins over env vars per src/config.ts.

# AWS account + region (region pinned to us-east-1; cross-region not in scope)
CDK_DEFAULT_ACCOUNT=825269749545
CDK_DEFAULT_REGION=us-east-1

# Deployment environment — one of: staging | prod
ENVIRONMENT=staging

# DNS / TLS
#   DOMAIN_APEX           — the registered apex managed at GoDaddy
#   SERVICE_HOSTNAME      — the per-env hostname pointing at the ALB
#                           (prod: api.cosentusaibackend.com,
#                            staging: staging.cosentusaibackend.com)
#   CERTIFICATE_ARN       — ARN of the wildcard cert (shared across envs,
#                           lives in CertStack). Leave blank until CertStack
#                           is deployed.
DOMAIN_APEX=cosentusaibackend.com
SERVICE_HOSTNAME=staging.cosentusaibackend.com
CERTIFICATE_ARN=

# Auto-scaling sizing (validated by Layer 9.5 — see docs/scale-test-report)
#   MIN_CAPACITY          — staging: 1, prod: 5
#   MAX_CAPACITY          — staging: 3, prod: 25
#   TARGET_SESSIONS_PCT   — 70 means scale out at 70% of max_concurrent_calls
MIN_CAPACITY=1
MAX_CAPACITY=3
TARGET_SESSIONS_PCT=70

# Per-task session capacity (matches MAX_CONCURRENT_CALLS in the engine)
SESSION_CAPACITY_PER_TASK=6

# NAT gateway count — staging: 1 (cost saving), prod: 3 (full AZ HA)
NAT_GATEWAYS=1

# S3 recordings bucket
#   prod:    medcloud-voice-us-prod-825 (existing v1 bucket, reused)
#   staging: cosentus-voice-engine-staging-recordings (CDK creates)
RECORDINGS_BUCKET_NAME=cosentus-voice-engine-staging-recordings
RECORDINGS_BUCKET_OWNED_BY_CDK=true
