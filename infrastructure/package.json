{
  "name": "cosentus-voice-engine-infrastructure",
  "version": "0.1.0",
  "private": true,
  "description": "AWS CDK stacks for the v2 voice engine — staging + prod.",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "synth:staging": "cdk synth -c environment=staging",
    "synth:prod": "cdk synth -c environment=prod",
    "diff:staging": "cdk diff -c environment=staging",
    "diff:prod": "cdk diff -c environment=prod",
    "deploy:staging": "cdk deploy --all -c environment=staging",
    "deploy:prod": "cdk deploy --all -c environment=prod --require-approval broadening"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "aws-cdk": "^2.180.0",
    "constructs": "^10.4.2",
    "dotenv": "^16.4.7",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.7.3"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.180.0"
  }
}
